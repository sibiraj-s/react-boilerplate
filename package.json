{
  "name": "react-boilerplate",
  "version": "0.0.0-boilerplate-template",
  "private": true,
  "description": "Minimal React Webpack Boilerplate",
  "keywords": [
    "react",
    "react-boilerplate",
    "tailwindcss",
    "webpack"
  ],
  "license": "MIT",
  "author": "sibiraj-s",
  "repository": "https://github.com/sibiraj-s/react-boilerplate",
  "scripts": {
    "lint": "oxlint . --ignore-path .gitignore --ext .js,.jsx",
    "dev": "webpack serve --mode=development --config-node-env=development",
    "build": "webpack --mode=production --config-node-env=production",
    "test": "vitest",
    "updateSnapshot": "vitest -u",
    "prepare": "is-ci || husky"
  },
  "dependencies": {
    "core-js": "^3.49.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "regenerator-runtime": "^0.14.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "babel-loader": "^10.1.1",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "happy-dom": "^20.8.9",
    "html-webpack-plugin": "^5.6.6",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "lint-staged": "^16.4.0",
    "mini-css-extract-plugin": "^2.10.2",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "postcss": "^8.5.8",
    "postcss-loader": "^8.2.1",
    "sass": "^1.98.0",
    "sass-loader": "^16.0.7",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.2.2",
    "vitest": "^4.1.2",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3",
    "webpack-merge": "^6.0.1"
  }
}
